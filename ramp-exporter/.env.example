# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Ramp API credentials (from Ramp developer portal)
RAMP_CLIENT_ID=your_client_id_here
RAMP_CLIENT_SECRET=your_client_secret_here

# Optional: override Ramp accounting field type strings if they differ
# (run  python main.py --dump-raw  to see actual type names)
# RAMP_FIELD_TYPE_GL_ACCOUNT=GL_ACCOUNT
# RAMP_FIELD_TYPE_DEPARTMENT=DEPARTMENT
# RAMP_FIELD_TYPE_VENDOR=ACCOUNTING_VENDOR

# Gmail credentials (use a Gmail App Password, not your main password)
# Google account > Security > 2-Step Verification > App passwords
GMAIL_USER=your.email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Where to send the CSV
NOTIFY_EMAIL=recipient@highlands.org

# Optional: folder to save the CSV (defaults to ./output/)
# OUTPUT_DIR=C:\ramp-to-sage\output

# Optional: folder for state files (exported IDs, last sent statement).
# Set this to a path OUTSIDE the ramp-exporter folder so state is preserved
# when you copy a new version of the scripts onto the server.
# STATE_DIR=C:\ramp-state

# Reimbursements: bank account credited by the single journal entry
# REIMBURSEMENT_BANK_ACCOUNT=1003-AB        # Bank/cash account (default 1003-AB)

# Bill pay: accounts used in the Payments Journal
# BILLPAY_CASH_ACCOUNT=1000-AB              # Bank account debited on payment (default 1000-AB)
# BILLPAY_AP_ACCOUNT=2200                   # AP clearing account credited (default 2200)

# Card payments: accounts used to clear open card-transaction AP invoices
# CARD_PAYMENT_CASH_ACCOUNT=1003-AB         # Bank account debited on payment (default 1003-AB)
# CARD_PAYMENT_AP_ACCOUNT=2104-AB           # AP account credited/cleared (default 2104-AB)
# CARD_PAYMENT_ENTITY_ID=                   # Optional: entity_id from balance_sections[0].entity_id
#                                           # in --dump-raw output for a Ramp Card statement.
#                                           # Set this to exclude Subscription statements.
